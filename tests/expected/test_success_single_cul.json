{
  "test_name": "test_success_single_cul",
  "description": "Single payment succeeds with CUL routing",
  "payments": [
    {
      "id": 0,
      "assertions": [
        {"field": "is_success", "op": "eq", "value": 1},
        {"field": "attempts", "op": "eq", "value": 1},
        {"field": "no_balance_count", "op": "eq", "value": 0},
        {"field": "route", "op": "not_empty"}
      ]
    }
  ],
  "edges": [
    {
      "id": 0,
      "assertions": [
        {"field": "balance", "op": "lt", "value": 5000000},
        {"field": "balance", "op": "gt", "value": 3900000}
      ]
    }
  ],
  "groups": []
}
